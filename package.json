{
  "name": "lambder",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f",
    "db:generate": "pnpm --filter @lambder/infra db:generate",
    "db:migrate": "pnpm --filter @lambder/infra db:migrate",
    "db:studio": "pnpm --filter @lambder/infra db:studio",
    "deploy:local": "serverless deploy --stage local",
    "deploy:dev": "serverless deploy --stage dev",
    "remove:local": "serverless remove --stage local",
    "gen:keys": "tsx scripts/generate-jwt-keys.ts"
  },
  "devDependencies": {
    "oxlint": "^0.11.0",
    "prettier": "^3.3.3",
    "rolldown": "^0.13.0",
    "serverless": "^4.4.0",
    "serverless-localstack": "^1.3.0",
    "tsx": "^4.19.0",
    "turbo": "^2.2.0",
    "typescript": "^5.6.0"
  }
}
