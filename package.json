{
  "name": "lambder",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f",
    "db:generate": "pnpm --filter @lambder/db db:generate",
    "db:migrate": "pnpm --filter @lambder/db db:migrate",
    "db:studio": "pnpm --filter @lambder/db db:studio",
    "deploy:local": "tsx scripts/deploy-localstack.ts",
    "gen:keys": "tsx scripts/generate-jwt-keys.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-apigatewayv2": "^3.1039.0",
    "@aws-sdk/client-iam": "^3.1039.0",
    "@aws-sdk/client-lambda": "^3.1039.0",
    "@types/adm-zip": "^0.5.8",
    "@vitest/coverage-v8": "^4.1.5",
    "adm-zip": "^0.5.17",
    "oxlint": "^0.11.0",
    "prettier": "^3.3.3",
    "rolldown": "1.0.0-rc.18",
    "tslib": "^2.8.1",
    "tsx": "^4.19.0",
    "turbo": "^2.2.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
