{
  "name": "e2e",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "test": "cucumber-js --config .cucumber.cjs",
    "test:headed": "HEADLESS=false cucumber-js --config .cucumber.cjs",
    "test:auth": "cucumber-js --config .cucumber.cjs --tags @auth",
    "test:products": "cucumber-js --config .cucumber.cjs --tags @products",
    "install:browsers": "playwright install chromium",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf test-results"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.1.0",
    "@faker-js/faker": "^9.0.0",
    "@lambder/tsconfig": "workspace:*",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.49.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  }
}
