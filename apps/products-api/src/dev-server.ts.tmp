import { config } from 'dotenv';
import { resolve } from 'node:path';
config({ path: resolve(process.cwd(), '../../.env') });
config();

// Init OTel BEFORE importing the instrumented app module.
const { initOTelSdk } = await import('@lambder/observability');
initOTelSdk({ serviceName: 'products-api' });

const { buildProductsApp } = await import('./app');

const port = Number.parseInt(process.env.PORT ?? '3002', 10);
serve({ fetch: buildProductsApp().fetch, port }, (info) => {
  console.log(`products-api listening on http://localhost:${info.port}`);
});
