import { config } from 'dotenv';
import { resolve } from 'node:path';
config({ path: resolve(process.cwd(), '../../.env') });
config();

// Init OTel BEFORE importing the instrumented app module.
const { initOTelSdk } = await import('@lambder/observability');
initOTelSdk({ serviceName: 'auth-api' });

const { buildAuthApp } = await import('./app');

const port = Number.parseInt(process.env.PORT ?? '3001', 10);
serve({ fetch: buildAuthApp().fetch, port }, (info) => {
  console.log(`auth-api listening on http://localhost:${info.port}`);
});
